SECRET_KEY=replace-with-a-strong-random-secret
DEBUG=False
USE_SQLITE=False
ALLOWED_HOSTS=localhost,127.0.0.1

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@example.com

# Delivery mode: smtp or resend
EMAIL_DELIVERY_PROVIDER=smtp

# Optional Resend config (recommended on Render Free where SMTP ports are blocked)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional Brevo config (works on Render Free via HTTPS API)
BREVO_API_KEY=
BREVO_FROM_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Blogify

DB_ENGINE=django.db.backends.postgresql
DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_NAME=blogify
DB_PWD=replace-with-strong-db-password
DATABASE_URL=postgresql://user:replace-with-strong-db-password@db:5432/blogify

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
